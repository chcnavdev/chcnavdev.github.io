;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;CoorKernal&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mCoorKernal&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Set of point coordinates&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;GpsTime&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mGpsTime&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Satellite time&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Time&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mTime&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Timing&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;SatellitePrecision&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;mSatellitePrecision&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Precision Information&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;double&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;diffAge&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Differential age&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;basewarning&#34;&gt;&#xA;  BaseWarning&#xA;  &lt;a class=&#34;anchor&#34; href=&#34;#basewarning&#34;&gt;#&lt;/a&gt;&#xA;&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Type&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Name&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Described&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;EnumBaseWarning&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;EnumBaseWarning&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Offset state&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h2 id=&#34;enumbasewarning&#34;&gt;&#xA;  EnumBaseWarning&#xA;  &lt;a class=&#34;anchor&#34; href=&#34;#enumbasewarning&#34;&gt;#&lt;/a&gt;&#xA;&lt;/h2&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Type&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Name&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: left&#34;&gt;Described&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;BASE_WARNING_NONE&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;BASE_WARNING_NONE&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;No offset&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;BASE_WARNING_BASE_MOVE&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;BASE_WARNING_BASE_MOVE&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: left&#34;&gt;Offset&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;</description>
